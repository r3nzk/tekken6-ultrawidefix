<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFrameworks>net8.0-windows;net8.0</TargetFrameworks>
    <RootNamespace>tekken6ultrawidefix</RootNamespace>
    <AssemblyName>tekken6ultrawidefix</AssemblyName>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <ApplicationIcon>assets\6fixicon.ico</ApplicationIcon>
  </PropertyGroup>

  <!--linux-->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0'">
    <PackageReference Include="Eto.Forms" Version="2.10.2" />
    <PackageReference Include="Eto.Platform.Gtk" Version="2.10.2" />
  </ItemGroup>

  <!--win-->
  <ItemGroup Condition="'$(TargetFramework)' == 'net8.0-windows'">
    <PackageReference Include="Eto.Forms" Version="2.10.2" />
    <PackageReference Include="Eto.Platform.Windows" Version="2.10.2" />
  </ItemGroup>

  <ItemGroup>
    <EmbeddedResource Include="assets\6fixicon.ico" />
  </ItemGroup> 
</Project>
